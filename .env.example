# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_client_id_here
QIMAH_GUILD_ID=your_guild_id_here

# Study System Configuration (optional - defaults provided)
# These override the hardcoded defaults in services/study/config.js
STUDY_CHANNEL_ID=
STUDY_LOG_CHANNEL_ID=
VOICE_CATEGORY_ID=
STUDY_ROLE_ID=
TAMOOH_ROLE_ID=
OWNER_ID=
QIMAH_TEAM_ROLE_ID=

# Weekly leaderboard reset summary channel
LEADERBOARD_CHANNEL_ID=              # Channel where Saturday weekly summary is posted

# Section Swap Configuration (optional)
SWAP_MATCHES_CHANNEL_ID=

# Course Thread Creator (optional)
FORUM_CHANNEL_ID=                    # Forum channel for course review threads

# Verification System Configuration (optional)
VERIFIED_ROLE_ID=                    # Role to assign when verified
VERIFY_CHANNEL_ID=                   # Channel where verify embed is posted
APPLICATION_LOG_CHANNEL_ID=          # Channel to log new member joins
VERIFICATION_LOG_CHANNEL_ID=         # Channel to log successful verifications
VERIFY_OAUTH_URL=                    # Qimah OAuth URL (optional, for Qimah members)
VERIFY_EMAIL_WEBHOOK_URL=            # n8n webhook URL for sending verification emails
VERIFY_ALLOWED_DOMAINS=stu.ksu.edu.sa  # Comma-separated list of allowed email domains
